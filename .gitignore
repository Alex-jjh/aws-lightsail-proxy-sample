.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ============================================================
# Secrets & Credentials
# ============================================================
*.pem
*.key
*.crt
*.p12
*.pfx
.env
.env.local
*-credentials.json
